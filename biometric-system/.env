SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml6dHZnYXVydmJza2pzZWhqc2huIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTUzNTI2NCwiZXhwIjoyMDk1MTExMjY0fQ.k9m9iVv2Wup-LfG99MSddeE3H6tU1kz8TwTBmNTjKnE

# --- APP ---
APP_ENV=development                    # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
# Génère une clé forte: openssl rand -hex 32
SECRET_KEY=83c0869ecd5bbddb55e1f6f1530cd0abd0f05a5dca2453e0f5705a724bfdd821

# --- CORS ---
# En dev, "*" est OK. En prod: liste séparée par virgules
CORS_ORIGINS=*

# --- IA / MODÈLES ---
FACE_DETECTION_MODEL=buffalo_l         # buffalo_l | buffalo_s (rapide)
EMBEDDING_MODEL=arcface_r100           # arcface_r100 | arcface_r50
ANTI_SPOOF_MODEL=minivision
MODEL_DIR=./models
SIMILARITY_THRESHOLD=0.6               # seuil reconnaissance (0.5-0.7)
LIVENESS_THRESHOLD=0.5                 # seuil anti-spoof

# --- KYC (Phase 3) ---
KYC_FACE_MATCH_THRESHOLD=0.70          # plus strict que reco standard
OCR_LANGUAGES=fra+eng                  # syntaxe Tesseract (ex: fra+eng+ara)

# --- Chiffrement embeddings (Phase 5) ---
# Active le chiffrement AES-GCM applicatif des vecteurs ArcFace.
# Génère une clé avec:  python -m security.encryption generate-key
EMBEDDING_ENCRYPTION_ENABLED=false
EMBEDDING_ENCRYPTION_KEY=487881d1dc1803742f6cc72ab9e518629e4787a797c6bbb39697a9d51543fe43

# --- Métriques (Phase 5) ---
METRICS_ENABLED=true                   # expose /metrics (Prometheus)

# --- SaaS multi-tenant (Phase 6) ---
# Le tenant est résolu via header X-API-Key (clé tenant) OU X-Tenant-Id
# (slug/uuid + JWT user). Cf. /api/v1/tenants pour la gestion.

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300                          # secondes (identités cachées)
RECOGNITION_CACHE_TTL=30               # cache résultats reco (par signature)

# --- FAISS ---
FAISS_RESYNC_INTERVAL_S=600            # re-sync depuis Supabase toutes les N sec

# --- STOCKAGE IMAGES (Supabase Storage) ---
STORAGE_BUCKET=biometric-media
MAX_IMAGE_SIZE_MB=5

# --- PERFORMANCE ---
GPU_ENABLED=false                      # true si CUDA disponible
BATCH_SIZE=8
MAX_FACES_PER_FRAME=10
FPS_TARGET=30

# --- SÉCURITÉ / JWT ---
JWT_EXPIRE_MINUTES=15                  # access token (court)
REFRESH_TOKEN_EXPIRE_MINUTES=43200     # refresh token (30j par défaut)
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=120
